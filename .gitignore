# ==========================================
# 🌌 Nexus: Bash & Linux Systems .gitignore
# ==========================================

# --- Script Artifacts ---
*.log
*.out
*.tmp
*.swp
# Ignore temporary directories created by scripts
tmp/
temp/

# --- Environment & Secrets (CRITICAL) ---
# Never commit credentials or local environment overrides
.env
.env.local
*.secret
*.pem
*.key

# --- Linux System & OS Files ---
# Ignore common "clutter" files generated by Linux/Unix
.DS_Store
.directory
.Trash-*
*~

# --- Editor & IDE Specifics ---
# Vim / Nano / VS Code
.vscode/
.idea/
.swo
.swn
.netrw
tags

# --- Archive & Compression ---
# Avoid store compressed backups of configs
*.tar
*.tar.gz
*.zip
*.7z
*.rar

# --- Shell History & Local Configs ---
# If any scripts generate history or local rc files
.bash_history
.zsh_history
.python_history

# --- Build & Binary ---
# If any scripts compile small C or Go utilities
bin/
dist/
*.o
*.so
